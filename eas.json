{
  "cli": {
    "version": ">= 18.3.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "env": {
        "APP_VARIANT": "development"
      },
      "developmentClient": true
    },

    "preview": {
      "env": {
        "APP_VARIANT": "preview"
      },
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
